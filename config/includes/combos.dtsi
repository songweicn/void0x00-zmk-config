/* KEY POSITIONS (using keypos_def helpers)
    ╭─────────────────────┬─────────────────────╮
    │ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
╭───╯ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 ╰───╮
│ LB5 LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 RB5 │
╰───────────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────────╯
            ╰─────────────┴─────────────╯       */

#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS, TERM, QUICKTAP, ...) \
    combo_##NAME { \
        timeout-ms = <TERM>; \
        bindings = <BINDINGS>; \
        key-positions = <KEYPOS>; \
        layers = <LAYERS>; \
        require-prior-idle-ms = <QUICKTAP>; \
        __VA_ARGS__ \
    };
/*  timeout-ms 기본 40~60. 얼마나 빠르게 눌러야 인식하는가.
    require-prior-idle-ms 100~150. 콤보키를 누르기 직전 얼마나 오랫동안 다른키 입력이 없어야 콤보로 작동하는가
    의도치않은 콤보입력 시 timeout-ms 줄임
    동시에 눌렀는데 콤보가 안 눌릴 때 timeout-ms 늘리거나 require-prior-idle-ms 줄임*/

/ {
    combos {
        compatible = "zmk,combos";
// top
COMBO(esc,    &kp ESC,     LT4 LT3,     DEF,          80, 100)

// middle
COMBO(lpar,   &kp LPAR,    LM2 LM1,     DEF,          40, 100)
COMBO(rpar,   &kp RPAR,    RM1 RM2,     DEF,          40, 100)
COMBO(lbkt,   &kp LBKT,    LM3 LM2,     DEF,          60, 100)
COMBO(rbkt,   &kp RBKT,    RM2 RM3,     DEF,          60, 100)

// bottom
COMBO(semi,   &kp SEMI,    RB1 RB2,     DEF,          40, 100)
COMBO(colon,  &kp COLON,   RB2 RB3,     DEF,          40, 100)
COMBO(mute,   &kp C_MUTE,  RB4 RB3,             NAV,  40, 200)
COMBO(plpu,   &kp C_PP,    RB2 RB1,             NAV,  40, 200)

// thumb

// cross
COMBO(capswd, &caps_word,  LM1 RM1,     DEF,          60, 200)
COMBO(stdio, &studio_unlock, LM0 RM0,   SYS,          80, 100)
COMBO(def,    &to DEF,     LM0 RM0,         NUM NAV,  80, 100)


// calc +-*/.,RET
COMBO(plus,   &kp PLUS,    LM2 LM1,     NUM,          40, 100)
COMBO(minus,  &kp MINUS,   LT2 LT1,     NUM,          80,  50)
COMBO(star,   &kp STAR,    LT2 LM1,     NUM,          80,  50)
COMBO(slash,  &kp SLASH,   LM2 LT1,     NUM,          80,  50)
COMBO(comma,  &kp COMMA,   LB2 LB1,     NUM,          40,  50)
COMBO(dot,    &kp DOT,     LB3 LB2,     NUM,          40,  50)
COMBO(ret_n,  &kp RET,     LM3 LM2,     NUM,          40, 100)

COMBO(plus_r,   &kp KP_PLUS,    RM2 RM1,   SYS,          40, 100)
COMBO(minus_r,  &kp KP_MINUS,   RT2 RT1,   SYS,          80,  50)
COMBO(star_r,   &kp KP_MULTIPLY,    RT1 RM2,   SYS,          80,  50)
COMBO(slash_r,  &kp KP_DIVIDE,   RM1 RT2,   SYS,          80,  50)
COMBO(comma_r,  &kp COMMA,   RB2 RB1,   SYS,          40,  50)
COMBO(dot_r,    &kp KP_DOT,     RB3 RB2,   SYS,          40,  50)
COMBO(ret_n_r,  &kp RET,     RM3 RM2,   SYS,          40, 100)
/*
COMBO(at,     &kp AT,      LT3 LT2,     DEF,          80, 100)
COMBO(hash,   &kp HASH,    LT2 LT1,     DEF,          80, 100)
COMBO(esc,    &kp ESC,     LT4 LT3,     DEF,          80, 100)
COMBO(del,    &kp DEL,     RT3 RT4,     DEF,          80,  50)
COMBO(bspc,   &kp BSPC,    RT1 RT2,     DEF,          80,  50)
COMBO(ret,    &kp RET,     RM3 RM1,     DEF,          40, 100)
COMBO(tab,    &kp TAB,     LM3 LM1,     DEF NUM NAV,  40, 100)
COMBO(batt,   &ind_bat,    LT0 RT0,     SYS,          80, 100)
COMBO(conn,   &ind_con,    LT1 RT1,     SYS,          80, 100)
COMBO(lock,   &kp LG(L),   LT0 RT0,     SYS,          80,  50)
COMBO(sleep,  &sleep,      LT1 RT1,     SYS,          80,  50)
COMBO(soft,   &soft_off,   LT2 RT2,     SYS,          80,  50)
*/
    };
};
